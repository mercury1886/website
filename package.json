{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"api/**/*.json\" \"scripts/**/*.{js,mjs}\" \"*.{js,json,md,yml,yaml}\" \".github/workflows/*.yml\" && prettier --write --plugin=@prettier/plugin-php \"api/**/*.php\"",
    "preview": "vite preview",
    "test:api": "docker compose run --rm --no-deps api composer test",
    "test": "docker compose run --rm --no-deps api composer test"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@prettier/plugin-php": "^0.25.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.4",
    "vite": "^8.0.10"
  }
}
